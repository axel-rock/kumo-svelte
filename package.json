{
  "name": "kumo-svelte-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "build": "pnpm --filter kumo-svelte build",
    "build:all": "pnpm -r build",
    "changeset": "tsx ci/scripts/ensure-changeset-config.ts && changeset",
    "check": "pnpm --filter kumo-svelte check",
    "deploy": "pnpm --filter kumo-svelte deploy",
    "deploy:kumo-docs-preview": "bash ci/versioning/deploy-kumo-docs-preview.sh",
    "deploy:kumo-docs-staging": "bash ci/versioning/deploy-kumo-docs-staging.sh",
    "dev": "pnpm --filter kumo-svelte dev",
    "format": "prettier --write \"**/*.{ts,js,json,md,css,svelte}\"",
    "lint": "oxlint --config .oxlintrc.json ci tools lint",
    "lockfile-check": "pnpm install --no-frozen-lockfile && git diff --exit-code pnpm-lock.yaml",
    "preview": "pnpm --filter kumo-svelte preview",
    "publish:beta": "bash ci/versioning/publish-beta.sh",
    "release": "pnpm build:all && changeset publish",
    "release:beta": "changeset publish --no-git-tag --tag beta",
    "typecheck": "pnpm --filter kumo-svelte typecheck",
    "version": "changeset version",
    "version:beta": "bash ci/versioning/version-beta.sh",
    "ci:post-pr-report": "tsx ci/scripts/post-pr-report.ts",
    "test:tools": "node --test --import tsx tools/deployments/validate-pr-description.test.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@octokit/rest": "^22.0.1",
    "@types/node": "^24.12.4",
    "@types/pngjs": "^6.0.5",
    "lefthook": "^2.0.12",
    "oxlint": "1.42.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  }
}
