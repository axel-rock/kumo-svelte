{
  "name": "kumo-svelte",
  "version": "0.3.0",
  "description": "Svelte port of Cloudflare's Kumo UI library using bits-ui primitives.",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxffarrell/kumo-svelte"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "kumo-svelte": "./dist/command-line/cli.js"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "ai",
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": {
      "types": "./dist/styles.css.d.ts",
      "default": "./dist/styles.css"
    },
    "./ai/component-registry.json": {
      "default": "./ai/component-registry.json"
    },
    "./registry/component-registry.json": "./ai/component-registry.json",
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "svelte": "./dist/components/*/index.js",
      "default": "./dist/components/*/index.js"
    },
    "./primitives": {
      "types": "./dist/primitives.d.ts",
      "svelte": "./dist/primitives.js",
      "default": "./dist/primitives.js"
    }
  },
  "scripts": {
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "codegen:registry": "tsx scripts/component-registry.ts",
    "build:cli": "tsc -p tsconfig.cli.json",
    "package": "svelte-package",
    "build:styles": "tsx scripts/build-package-css.ts",
    "build": "pnpm codegen:registry && pnpm check && pnpm package && pnpm build:styles && pnpm build:cli && vite build",
    "deploy": "pnpm build && wrangler deploy",
    "dev": "pnpm codegen:registry && vite dev",
    "preview": "vite preview",
    "test": "CI=true vitest run",
    "test:run": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest --watch",
    "typecheck": "pnpm check"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.60.1",
    "echarts": "^6.0.0",
    "svelte": "^5.55.7"
  },
  "peerDependenciesMeta": {
    "@sveltejs/kit": {
      "optional": true
    },
    "echarts": {
      "optional": true
    }
  },
  "dependencies": {
    "@internationalized/date": "^3.12.2",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "esm-env": "^1.2.2",
    "phosphor-svelte": "^3.1.0",
    "shiki": "^4.2.0",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.65.2",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "happy-dom": "^20.10.5",
    "jsdom": "^29.1.1",
    "mdsx": "^0.0.7",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wrangler": "^4.101.0"
  }
}
